node_modules/
package-lock.json

# Local agent state (no commit)
.claude/

# QA screenshots ad-hoc en la raíz (los del juego van en .planning/qa-screenshots/)
qa-juego*.png
qa-*.png

# Artefactos locales de QA con Playwright
.qa-server.js
.playwright-mcp/

# QA visual — capturas y resumen se regeneran en cada corrida.
**/.planning/qa-screenshots/
**/.planning/qa-shots/
**/.planning/verify-shots/
**/.planning/verify-shots-b/
**/.planning/smoke-shots/
**/.planning/qa-results.json
**/.planning/qa-overlap-results.json

# Capturas y scripts temporales ad-hoc en la raíz (se regeneran al hacer QA).
.tmp-screenshots/
.tmp-*.js
v?-*.png

# Contador de visitas server-side (estado de producción, no se commitea)
juegos/*/visits.txt
juegos/*/counts/

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini
